# Committed template for the local-only .env file.
# Copy this to .env (gitignored) and fill in real values:
#
#   cp .env.example .env
#   $EDITOR .env
#   set -a; source .env; set +a
#
# Variables the cairn CLI reads from the environment:

# Dev MCP server URL. `cairn dev fixtures` and `cairn dev scaffold-fixture`
# default --remote to this when set (ADR-0013). Unguessable hostname is the
# capability — keep the real value out of git.
CAIRN_DEV_REMOTE_URL=https://cairn-mcp-<replace-me>.services.dsi.wisc.edu/mcp

# Bearer token for HTTP MCP servers that enforce auth. Read directly by
# cairn.credentials.resolve_token; alternatively stored per-endpoint in
# ~/.config/cairn/credentials.toml.
CAIRN_BEARER_TOKEN=

# Override the user-level registry path (ADR-0013). Mostly used by
# `cairn dev serve` to give each dev server its own sandboxed registry;
# leave unset for normal use.
# CAIRN_REGISTRY_PATH=
