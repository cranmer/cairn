# Cairn — default ignores for a research project repository

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*~
*.swp

# Python (if any project tooling lives in-repo)
__pycache__/
*.py[cod]
.venv/
.pixi/
*.egg-info/

# Notebooks
.ipynb_checkpoints/

# Local-only data
/data/local/
/scratch/

# Claude Code per-user, per-machine settings (paths are local to the user's box).
# The shared, committed config lives in .claude/settings.json — keep that.
.claude/settings.local.json
